# Pipeline Execution Environment (local or production)
ENVIRONMENT=local

# Local File System Paths (relative to project root)
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
ARCHIVE_DATA_DIR=data/archive
LOG_DIR=logs

# Database Configuration (MySQL / AWS RDS)
# For local Docker:
DB_HOST=localhost
DB_PORT=3306
DB_USER=sales_user
DB_PASSWORD=sales_secure_password
DB_NAME=sales_data

# AWS Credentials and S3 Configuration
# Required for extraction/loading from/to cloud
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=your-sales-etl-bucket-name-here
